DEEPSEEK_API_KEY=your-deepseek-api-key
# OPENAI_API_KEY=your-openai-api-key

# Optional overrides
# SPEC_MODEL=deepseek-chat
# CODE_MODEL=deepseek-chat
# REPAIR_MODEL=deepseek-chat
# CRITIC_PROVIDER=deepseek
# CRITIC_MODEL=deepseek-chat
# CRITIC_PROBE_PROVIDER=deepseek
# CRITIC_PROBE_MODEL=deepseek-chat
# CRITIC_TEMPERATURE=0.0
# CRITIC_MAX_TOKENS=1800
# CRITIC_PROBE_MAX_TOKENS=1200
# MAX_CRITIC_PROBE_PARSE_RETRIES=2
# MIN_CRITIC_PROBES=3
# MAX_CRITIC_PROBES=6
# MAX_EXECUTED_CRITIC_PROBES=12  # per execution batch; mandatory evidence is never truncated
# CRITIC_REQUIRE_PRECONDITION_EVIDENCE=1
# LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=0
# MAX_REPAIR_ROUNDS=3
# EVALUATION_MODE=strict
# USE_TEMPLATE_FALLBACK=0
# ENABLE_SPEC_REPAIR=1
# MAX_SPEC_REPAIR_RETRIES=2
# ENABLE_PROOF_REPAIR=1
# ENABLE_BEHAVIOR_REPAIR_LOOP=1
# ENABLE_INLOOP_MUTATION_ADEQUACY=1
# ENABLE_MUTATION_SPEC_STRENGTHENING=1
# MAX_MUTATION_STRENGTHENING_ROUNDS=1
# ENABLE_SPEC_CRITIC=1
# MAX_CRITIC_REPAIR_ROUNDS=1
# MAX_CRITIC_PARSE_RETRIES=1
# CRITIC_REVIEW_PASSES=1
# DAFNY_PATH=/path/to/dafny
# DATA_DIR=/path/to/data
# LOG_DIR=/path/to/logs
# RUNS_DIR=/path/to/logs/runs
